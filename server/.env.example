# Port configuration
PORT=5000

# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/enclave_portal

# JWT Security
JWT_SECRET=supersecretjwtsecretkeychangeinproduction123!
JWT_EXPIRES_IN=1d

# Nodemailer SMTP settings (use real SMTP configuration or default fallbacks)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@enclaveportal.com

# Cloudinary credentials (for image upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Node Environment
NODE_ENV=development
